# Copy this file to .env and fill in your key.
# Used server-side only — never exposed to the browser.
OPENAI_API_KEY=

PORT=3001

# ── Database (accounts, audit history, plan limits) ───────────
# Postgres connection string. On Railway, add a Postgres plugin and it
# provides DATABASE_URL automatically. Leave blank to run without accounts.
DATABASE_URL=

# Set to "false" if your Postgres does not use TLS (e.g. Railway's private
# network). Defaults to TLS for remote hosts, off for localhost.
DATABASE_SSL=

# Set to "production" so session cookies are marked Secure (HTTPS only).
NODE_ENV=

# ── OpenAI tuning (optional) ──────────────────────────────────
# Model and per-request timeout/retry behaviour.
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=3

# ── Hardening (optional) ──────────────────────────────────────
# Max analysis requests per IP per hour (caps OpenAI spend).
ANALYZE_RATE_LIMIT=20

# Comma-separated CORS allowlist. Leave blank to send no cross-origin
# headers (the same-origin UI works either way).
ALLOWED_ORIGINS=

# Set BOTH to put the whole app behind an HTTP Basic Auth login.
# Leave blank to keep it open.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
